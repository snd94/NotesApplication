@using Notes.Application.Dto
@using Notes.Domain
@model IEnumerable<NoteDto>

@{
    ViewData["Title"] = "ListNotes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">Notes</h2>
        <a asp-action="Create" class="btn btn-success">+ Create New</a>
    </div>

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.Content)</th>
                <th>@Html.DisplayNameFor(model => model.Priority)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>

            @foreach (var item in Model)
            {
                var rowClass = item.Priority switch
                {
                    PriorityLevel.Low => "table-success",   // green
                    PriorityLevel.Medium => "table-warning", // yellow
                    PriorityLevel.High => "table-danger", //red
                    PriorityLevel.Critical => "table-danger",   // red
                    _ => ""
                };

                <tr class="@rowClass">
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.Content)</td>
                    <td>@Html.DisplayFor(modelItem => item.Priority)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>